#!/bin/bash

# FingerDump post-installation script (rootless)

JB=/var/jb

# Create data directories
mkdir -p /var/mobile/Library/FingerDump/www
mkdir -p /var/mobile/Library/FingerDump/reports
mkdir -p /var/run/fingerdumpd

# Set permissions
chmod 755 $JB/usr/libexec/fingerdumpd
chmod 644 $JB/Library/MobileSubstrate/DynamicLibraries/FingerDumpTweak.dylib
chmod 644 $JB/Library/MobileSubstrate/DynamicLibraries/FingerDumpTweak.plist

# Start the daemon (ignore failures on rootless)
$JB/usr/libexec/fingerdumpd --daemon 2>/dev/null || true

echo "FingerDump installed successfully."
echo "Run 'fingerdumpd --scan' for a CLI scan."
echo "Tweak is active. Check /var/mobile/Library/FingerDump/api_calls.log for traces."
